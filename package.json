{
  "name": "ai-studio-angular-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node server.mjs",
    "dev": "cross-env ng serve --port=3000 --host=0.0.0.0 --allowed-hosts --define=\"GEMINI_API_KEY=\\\"'${GEMINI_API_KEY}'\\\"\" ${DISABLE_HMR:+--live-reload=false}",
    "build": "cross-env ng build --define=\"GEMINI_API_KEY=\\\"'${GEMINI_API_KEY}'\\\"\"",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "serve:ssr:app": "node dist/app/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/ssr": "^21.0.0",
    "@google/genai": "^1.27.0",
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/typography": "^0.5.19",
    "cross-env": "^10.1.0",
    "express": "^5.1.0",
    "linkedom": "^0.18.12",
    "marked": "^18.0.0",
    "motion": "^12.23.24",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/marked": "^5.0.2",
    "@types/mozilla-readability": "^0.2.1",
    "@types/node": "^20.17.19",
    "@types/turndown": "^5.0.6",
    "angular-eslint": "21.1.0",
    "eslint": "^9.39.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.47.0",
    "vitest": "^4.0.0"
  }
